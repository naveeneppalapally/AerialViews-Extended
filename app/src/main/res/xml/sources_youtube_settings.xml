<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

        <Preference
            app:key="yt_cache_warning"
            app:title="@string/youtube_cache_empty_title"
            app:summary="@string/youtube_cache_empty_summary"
            app:selectable="false"
            app:isPreferenceVisible="false" />

        <PreferenceCategory app:title="@string/category_video_source">
                <SwitchPreference
                    app:defaultValue="true"
                    app:key="yt_enabled"
                    app:title="@string/youtube_enabled_title" />

                <Preference
                    app:dependency="yt_enabled"
                    app:disableDependentsState="false"
                    app:key="yt_refresh_now"
                    app:title="@string/youtube_refresh_now_title"
                    app:summary="@string/youtube_refresh_now_summary" />
        </PreferenceCategory>

        <PreferenceCategory app:title="@string/youtube_search_category_title">
                <Preference
                    app:dependency="yt_enabled"
                    app:disableDependentsState="false"
                    app:key="yt_formula_info"
                    app:title="@string/youtube_formula_info_title"
                    app:selectable="false" />

                <SeekBarPreference
                    app:dependency="yt_enabled"
                    app:disableDependentsState="false"
                    app:key="yt_min_duration"
                    app:title="@string/youtube_min_duration_title"
                    app:min="5"
                    android:max="60"
                    app:showSeekBarValue="true"
                    app:defaultValue="10" />
        </PreferenceCategory>

        <PreferenceCategory app:title="@string/youtube_playlist_category_title">
                <ListPreference
                    app:dependency="yt_enabled"
                    app:disableDependentsState="false"
                    app:key="yt_quality"
                    app:title="@string/youtube_quality_title"
                    app:entries="@array/youtube_quality_entries"
                    app:entryValues="@array/youtube_quality_values"
                    app:defaultValue="@string/youtube_quality_default"
                    app:useSimpleSummaryProvider="true" />

                <SwitchPreference
                    app:dependency="yt_enabled"
                    app:disableDependentsState="false"
                    app:key="yt_shuffle"
                    app:title="@string/youtube_shuffle_title"
                    app:defaultValue="true" />
        </PreferenceCategory>
</PreferenceScreen>
